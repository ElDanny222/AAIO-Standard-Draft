{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://aaio-standard.org/schemas/aaio-scoring.schema.json",
  "title": "AAIO Readiness Score",
  "description": "Machine-readable output format for AAIO Readiness Score assessments. Defines the structure of scoring results produced by AAIO audits.",
  "type": "object",
  "required": ["schemaVersion", "assessmentDate", "target", "score", "categories"],
  "properties": {
    "$schema": {
      "type": "string",
      "description": "Reference to this JSON Schema"
    },
    "schemaVersion": {
      "type": "string",
      "description": "Version of this scoring schema",
      "const": "0.1"
    },
    "assessmentDate": {
      "type": "string",
      "format": "date-time",
      "description": "ISO 8601 timestamp of when the assessment was conducted"
    },
    "assessor": {
      "type": "string",
      "description": "Entity or tool that conducted the assessment"
    },
    "target": {
      "type": "object",
      "description": "The website or service being assessed",
      "required": ["url", "name"],
      "properties": {
        "url": {
          "type": "string",
          "format": "uri",
          "description": "Base URL of the assessed website"
        },
        "name": {
          "type": "string",
          "description": "Name of the assessed website or service"
        },
        "industry": {
          "type": "string",
          "description": "Industry or vertical of the assessed site"
        },
        "country": {
          "type": "string",
          "description": "Primary country of operation (ISO 3166-1 alpha-2)"
        }
      }
    },
    "score": {
      "type": "object",
      "description": "Overall AAIO Readiness Score",
      "required": ["total", "tier"],
      "properties": {
        "total": {
          "type": "number",
          "minimum": 0,
          "maximum": 100,
          "description": "Total AAIO Readiness Score (0-100)"
        },
        "tier": {
          "type": "string",
          "enum": ["F", "D", "C", "B", "A"],
          "description": "Score tier: F (0-19), D (20-39), C (40-59), B (60-79), A (80-100)"
        },
        "label": {
          "type": "string",
          "enum": ["Not Ready", "Basic", "Developing", "Agent-Ready", "Agent-Optimized"],
          "description": "Human-readable tier label"
        }
      }
    },
    "categories": {
      "type": "object",
      "description": "Scores broken down by the four AAIO pillars",
      "required": ["discovery", "readability", "navigability", "transactability"],
      "properties": {
        "discovery": {
          "$ref": "#/$defs/categoryScore",
          "description": "Discovery pillar score (max 20 points)"
        },
        "readability": {
          "$ref": "#/$defs/categoryScore",
          "description": "Machine-Readability pillar score (max 35 points)"
        },
        "navigability": {
          "$ref": "#/$defs/categoryScore",
          "description": "Navigability pillar score (max 20 points)"
        },
        "transactability": {
          "$ref": "#/$defs/categoryScore",
          "description": "Transactability pillar score (max 25 points)"
        }
      }
    },
    "conformanceLevel": {
      "type": "string",
      "enum": ["none", "basic", "standard", "commerce", "full"],
      "description": "AAIO conformance level achieved"
    },
    "transactionLevel": {
      "type": "string",
      "enum": ["L0", "L1", "L2", "L3"],
      "description": "Transaction maturity level"
    },
    "protocols": {
      "type": "object",
      "description": "Protocol support detected during assessment",
      "properties": {
        "mcp": { "type": "boolean" },
        "acp": { "type": "boolean" },
        "ucp": { "type": "boolean" },
        "a2a": { "type": "boolean" }
      }
    },
    "recommendations": {
      "type": "array",
      "description": "Prioritized list of recommendations to improve the score",
      "items": {
        "type": "object",
        "required": ["category", "priority", "title", "description", "pointsAvailable"],
        "properties": {
          "category": {
            "type": "string",
            "enum": ["discovery", "readability", "navigability", "transactability"]
          },
          "priority": {
            "type": "string",
            "enum": ["critical", "high", "medium", "low"]
          },
          "title": {
            "type": "string",
            "description": "Short title for the recommendation"
          },
          "description": {
            "type": "string",
            "description": "Detailed description of what to implement"
          },
          "pointsAvailable": {
            "type": "number",
            "minimum": 0,
            "description": "Potential score points gained by implementing this recommendation"
          },
          "effort": {
            "type": "string",
            "enum": ["low", "medium", "high"],
            "description": "Estimated implementation effort"
          }
        }
      }
    },
    "metadata": {
      "type": "object",
      "description": "Additional assessment metadata",
      "properties": {
        "toolVersion": {
          "type": "string",
          "description": "Version of the assessment tool used"
        },
        "pagesAnalyzed": {
          "type": "integer",
          "minimum": 0,
          "description": "Number of pages analyzed during the assessment"
        },
        "duration": {
          "type": "number",
          "description": "Assessment duration in seconds"
        },
        "notes": {
          "type": "string",
          "description": "Free-text notes from the assessor"
        }
      }
    }
  },
  "$defs": {
    "categoryScore": {
      "type": "object",
      "required": ["score", "maxScore", "checks"],
      "properties": {
        "score": {
          "type": "number",
          "minimum": 0,
          "description": "Points scored in this category"
        },
        "maxScore": {
          "type": "number",
          "minimum": 0,
          "description": "Maximum possible points in this category"
        },
        "percentage": {
          "type": "number",
          "minimum": 0,
          "maximum": 100,
          "description": "Percentage score for this category"
        },
        "checks": {
          "type": "array",
          "description": "Individual checks within this category",
          "items": {
            "type": "object",
            "required": ["name", "passed", "points", "maxPoints"],
            "properties": {
              "name": {
                "type": "string",
                "description": "Name of the check"
              },
              "passed": {
                "type": "boolean",
                "description": "Whether the check passed"
              },
              "points": {
                "type": "number",
                "minimum": 0,
                "description": "Points awarded for this check"
              },
              "maxPoints": {
                "type": "number",
                "minimum": 0,
                "description": "Maximum points possible for this check"
              },
              "details": {
                "type": "string",
                "description": "Additional details about the check result"
              }
            }
          }
        }
      }
    }
  },
  "additionalProperties": false
}
